root = true

### actual necessary configurations

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

### pointless tab/space opinions below

[*.{awk,c,cpp,go,h,hpp,java,lua,make,md,mk,rst,sh},Makefile,Makefile.*]
indent_style = tab
tab_width = 8

[*.{js,ts,jsx,tsx,html,css,vue,rb,json,yaml,yml,xml,toml}]
indent_style = space
indent_size = 2

[*.{py,rs}]
indent_style = space
indent_size = 4

