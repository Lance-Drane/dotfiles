[alias]
	pushf = push --force-with-lease --force-if-includes
[branch]
	sort = -committerdate
[diff]
	submodule = log
[fetch]
	prune = true
[init]
	defaultBranch = main
[pull]
	rebase = true
[push]
	autoSetupRemote = true
	default = simple
[tag]
	sort = -version:refname
[url "https://github.com/"]
	insteadOf = ssh://git@github.com
[user]
	email = Lance-Drane@users.noreply.github.com
	name = Lance-Drane
